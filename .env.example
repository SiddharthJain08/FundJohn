# === LLM ===
ANTHROPIC_API_KEY=your_key_here

# === DATA (Tier 1 — Primary) ===
FMP_API_KEY=your_key_here
POLYGON_API_KEY=your_key_here
ALPHA_VANTAGE_API_KEY=your_key_here
TAVILY_API_KEY=your_key_here

# === DATA (Tier 2 — Fallback) ===
# Yahoo Finance — no key needed (yfinance)

# === FILINGS ===
SEC_USER_AGENT=OpenClaw/1.0 (your_email@example.com)

# === DATABASE ===
POSTGRES_URI=postgresql://openclaw:password@localhost:5432/openclaw
REDIS_URL=redis://localhost:6379

# === DISCORD ===
DISCORD_BOT_TOKEN=your_token_here
ALLOWED_CHANNEL_IDS=
ALLOWED_USER_IDS=

# === RUNTIME ===
CLAUDE_BIN=/usr/local/bin/claude-bin
CLAUDE_UID=1001
CLAUDE_GID=1001
CLAUDE_HOME=/home/claudebot
OPENCLAW_DIR=/root/openclaw

# === SANDBOX ===
SANDBOX_TYPE=local
# DAYTONA_API_KEY=your_key_here  # if using Daytona cloud sandboxes

# === MEMORY RETRIEVAL (pgvector + Voyage embeddings) ===
# Embed pipeline writes to memory_chunks (migration 054). Retrieval middleware
# (workspace-context.js) prefers retrieval when MEMORY_RETRIEVAL=on AND chunks
# exist; else falls back to wholesale memory/*.md injection. See
# /root/.claude/plans/go-through-this-deep-wand.md §9 for the runbook.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
MEMORY_RETRIEVAL=          # set to 'on' after backfill populates memory_chunks
MEMORY_RETRIEVAL_K=8       # top-K chunks per retrieval (optional override)
